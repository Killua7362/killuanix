#!/usr/bin/env bash
# nix_switch: apply the killuanix flake — system, home, or both — with an
# optional --limit flag that throttles CPU/RAM/IO so a heavy rebuild doesn't
# wedge the machine while you use it for other things.
#
# Usage:
#   nix_switch                         home only (host autodetected)
#   nix_switch home                    home only
#   nix_switch system                  system only
#   nix_switch both                    system, then home
#   nix_switch --host chrollo both     pick the flake host explicitly
#   nix_switch --limit both            throttle the build (see below)
#   nix_switch --no-nh home            force raw nix build path even if nh present
#   nix_switch --no-fast home          disable lazy-trees + eval-cache flags
#
# Hosts: chrollo, killua, archnix.
#   Autodetected when --host is omitted:
#     * NixOS       -> /etc/hostname (must be chrollo or killua)
#     * Arch Linux  -> archnix (/etc/arch-release present)
#
# --limit applies:
#   * nix --max-jobs 2 --cores 2   (caps build parallelism)
#   * nice -n 19 + ionice -c 3     (soft CPU + IO priority)
#   * systemd-run --user --scope with CPUQuota=200% + MemoryMax=4G
#     (hard cgroup caps, user-side commands only)
# Omit --limit for a full-speed build.
#
# Speed stack (enabled by default, disable with --no-fast):
#   * lazy-trees experimental feature  — skips fetching unused flake inputs.
#   * eval-cache = true                — persists flake eval across runs.
#   Both are injected via NIX_CONFIG so nh / nixos-rebuild / nix build all
#   inherit them automatically.
#
# nh integration (enabled by default when `nh` is on PATH, disable with --no-nh):
#   * `nh os switch`   replaces `nixos-rebuild switch` for chrollo / killua,
#     giving a colored closure diff before activation.
#   * `nh home switch` replaces `nix build + activate` for the home path,
#     same diff preview. Requires `homeConfigurations.<host>` in the flake
#     (aliased to `homeManagerConfigurations.<host>` — see flake.nix).
#   archnix system still goes through `system-manager` (nh has no shim).
#
# The flake dir defaults to $HOME/killuanix; override with $KILLUANIX_FLAKE.

set -euo pipefail

readonly FLAKE_DIR="${KILLUANIX_FLAKE:-$HOME/killuanix}"

log()  { printf '\033[1;34m[nix_switch]\033[0m %s\n' "$*" >&2; }
warn() { printf '\033[1;33m[nix_switch]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[nix_switch]\033[0m %s\n' "$*" >&2; exit 1; }

usage() {
  sed -n '2,40p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# ── Parse args ────────────────────────────────────────────────
mode=""
host=""
limit=false
use_nh=true
use_fast=true

while [ $# -gt 0 ]; do
  case "$1" in
    home|system|both)
      [ -n "$mode" ] && die "mode already set to '$mode'; extra arg: $1"
      mode="$1"; shift ;;
    --host)
      [ $# -ge 2 ] || die "--host needs a value"
      host="$2"; shift 2 ;;
    --host=*)
      host="${1#--host=}"; shift ;;
    --limit)
      limit=true; shift ;;
    --no-nh)
      use_nh=false; shift ;;
    --no-fast)
      use_fast=false; shift ;;
    -h|--help)
      usage 0 ;;
    *)
      die "unknown argument: $1 (try --help)" ;;
  esac
done

mode="${mode:-home}"

# ── Autodetect host ───────────────────────────────────────────
if [ -z "$host" ]; then
  if [ -e /run/current-system ] && [ -r /etc/hostname ]; then
    host="$(tr -d '[:space:]' < /etc/hostname)"
    case "$host" in
      chrollo|killua) ;;
      *) die "NixOS hostname '$host' doesn't map to a flake output; pass --host explicitly" ;;
    esac
  elif [ -e /etc/arch-release ]; then
    host="archnix"
  else
    die "could not autodetect host; pass --host chrollo|killua|archnix"
  fi
  log "autodetected host: $host"
fi

case "$host" in
  chrollo|killua|archnix) ;;
  *) die "unsupported host: $host (expected chrollo|killua|archnix)" ;;
esac

# ── Speed stack: eval-cache (defaults already cover the rest) ────
# Determinate Nix already enables `lazy-trees` as a top-level option (it's
# NOT an experimental-feature flag — injecting it as one prints a warning)
# and ships parallel daemon marshalling internally without a knob. Lix has
# similar defaults. We therefore only set `eval-cache = true` (default-on
# since Nix 2.4, restated defensively) and log the detected runtime so it's
# obvious which speedups are actually live.
#
# NIX_CONFIG is read by every nix client (nh, nixos-rebuild, nix build,
# nix run). We append rather than replace so existing nix.conf survives.
if $use_fast; then
  fast_lines=("eval-cache = true")
  nix_ver="$(nix --version 2>/dev/null || true)"
  case "$nix_ver" in
    *Determinate*)
      log "fast: Determinate Nix detected — lazy-trees + parallel marshalling active by default"
      ;;
    *Lix*)
      log "fast: Lix detected — lazy-trees / parallel paths covered by Lix defaults"
      ;;
    *)
      log "fast: upstream nix (${nix_ver:-unknown}) — eval-cache only; install Determinate Nix or Lix for lazy-trees"
      ;;
  esac
  fast_conf="$(IFS=$'\n'; echo "${fast_lines[*]}")"
  if [ -n "${NIX_CONFIG:-}" ]; then
    export NIX_CONFIG="${NIX_CONFIG}"$'\n'"${fast_conf}"
  else
    export NIX_CONFIG="${fast_conf}"
  fi
fi

# ── Detect nh ─────────────────────────────────────────────────
nh_available=false
if $use_nh && command -v nh >/dev/null 2>&1; then
  nh_available=true
fi

# ── Build command wrappers for --limit ─────────────────────────
nix_flags=()
user_wrap=()
sys_wrap=()

if $limit; then
  nix_flags=(--max-jobs 2 --cores 2)
  sys_wrap=(nice -n 19 ionice -c 3)
  if command -v systemd-run >/dev/null 2>&1; then
    user_wrap=(
      systemd-run --user --scope --quiet --collect
      -p CPUQuota=200%
      -p MemoryMax=4G
      -p MemorySwapMax=0
      -p IOWeight=50
      -- nice -n 19 ionice -c 3
    )
  else
    warn "systemd-run not available; falling back to nice+ionice only for user commands"
    user_wrap=(nice -n 19 ionice -c 3)
  fi
  log "limits: cpu=200% mem=4G max-jobs=2 cores=2 nice=19 ionice=3"
fi

# nh forwards extra args to the underlying builder after `--`.
# Always pass --impure to match the raw paths (flake reads env / current-system).
nh_passthrough=(-- --impure)
if [ "${#nix_flags[@]}" -gt 0 ]; then
  nh_passthrough+=("${nix_flags[@]}")
fi

# ── Actions ───────────────────────────────────────────────────
do_home() {
  if $nh_available; then
    log "home: nh home switch -c ${host} ${FLAKE_DIR}"
    "${user_wrap[@]}" nh home switch -c "$host" "$FLAKE_DIR" "${nh_passthrough[@]}"
    return
  fi

  # Fallback: build the activation package directly and run its `activate`
  # script. We don't use `home-manager switch --flake .#<host>` here because
  # the user may not have the HM CLI on PATH; raw `nix build` works anywhere.
  local attr="homeManagerConfigurations.${host}.activationPackage"
  local link="$FLAKE_DIR/.hm-result"
  log "home: nix build .#${attr} && ./activate (no nh)"
  ( cd "$FLAKE_DIR" \
    && "${user_wrap[@]}" nix build \
       --extra-experimental-features 'nix-command flakes' \
       --impure \
       --out-link "$link" \
       ".#${attr}" "${nix_flags[@]}" \
    && "${user_wrap[@]}" "$link/activate" )
  rm -f "$link"
}

do_system() {
  case "$host" in
    chrollo|killua)
      if $nh_available; then
        # nh refuses to run under sudo — it escalates internally for the
        # activation step. We just wrap with the user-side throttle (if any)
        # and let nh prompt for the password when it needs root.
        # Note: --limit's cgroup scope only constrains the user-side eval;
        # the daemon does the heavy build work and lives outside our scope,
        # same as the raw `nixos-rebuild` path.
        log "system: nh os switch -H ${host} ${FLAKE_DIR}"
        "${user_wrap[@]}" nh os switch -H "$host" "$FLAKE_DIR" "${nh_passthrough[@]}"
        return
      fi
      log "system: nixos-rebuild switch --flake .#${host} (no nh)"
      ( cd "$FLAKE_DIR" \
        && sudo "${sys_wrap[@]}" nixos-rebuild switch \
           --impure \
           --flake ".#${host}" "${nix_flags[@]}" )
      ;;
    archnix)
      # system-manager isn't typically on PATH; run it out of the flake input.
      # nh has no system-manager shim, so this path stays raw regardless.
      log "system: system-manager switch --flake .#default"
      ( cd "$FLAKE_DIR" \
        && sudo "${sys_wrap[@]}" nix run \
           --extra-experimental-features 'nix-command flakes' \
           'github:numtide/system-manager' -- \
           switch --flake '.#default' )
      ;;
  esac
}

case "$mode" in
  home)
    do_home
    ;;
  system)
    do_system
    ;;
  both)
    # Gate home on the system switch: if nixos-rebuild (or system-manager)
    # fails, do not touch the user profile. `set -e` would already bail, but
    # the explicit check gives a clearer error and prevents future refactors
    # from accidentally introducing a code path that runs do_home anyway.
    if ! do_system; then
      die "system switch failed — home switch skipped to avoid drift"
    fi
    do_home
    ;;
esac

log "done (${mode} on ${host})"
