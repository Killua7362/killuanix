# direnv: exports QML_IMPORT_PATH so qmlls6 (-E) resolves `qs.*` + Qt6 modules.
# Cache tree is built by home.activation.qmlWorkspaceImportTree in default.nix.

CACHE="$HOME/.cache/qml-workspace"

if [ ! -d "$CACHE/qs" ]; then
  echo "qml-workspace: cache missing — run scripts/nix_switch to rebuild" >&2
fi

QT_QML="$(cat "$CACHE/QT_QML_PATH" 2>/dev/null || true)"

export QML_IMPORT_PATH="$CACHE${QT_QML:+:$QT_QML}"
export QML2_IMPORT_PATH="$QML_IMPORT_PATH"
