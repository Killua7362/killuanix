+# Workaround for Python 3.13 + LibreOffice's UNO `__import__` hook:
+# `mimetypes.py` does `from _winapi import _mimetypes_read_windows_registry`
+# in a try/except ImportError block. On Linux Python that normally fails with
+# ImportError, but LO's uno.py turns missing modules into UNO class lookups
+# that raise SystemError instead — bypassing mimetypes' try/except and
+# blowing up anything that imports `http.server` (which we need for the MCP
+# HTTP server). Pre-registering a dummy `_winapi` module short-circuits the
+# import so mimetypes' `from _winapi import <attr>` hits AttributeError-as-
+# ImportError naturally.
+if sys.platform != "win32":
+    import types as _types
+    sys.modules.setdefault("_winapi", _types.ModuleType("_winapi"))
+
 from com.sun.star.lang import XServiceInfo
