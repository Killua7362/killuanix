+# Auto-start MCP HTTP server on extension load.
+# Workaround: LO's framework returns its built-in `ServiceHandler` stub for
+# `service:org.mcp.libreoffice.MCPExtension*` URLs instead of routing to this
+# extension's `MCPProtocolHandler`, so menu/toolbar clicks never reach
+# `dispatch` and the server never starts. The auto-start fires when this
+# module is first imported (which happens early — LO probes menubar/toolbar
+# dispatchers at startup). `_start_server` is idempotent via `_lock` +
+# `_server_started`, so repeated imports are safe.
+threading.Thread(target=_start_server, daemon=True).start()
